# Local development configuration
# Choose one runtime provider block below and keep the others commented out.
# For deployment, these are set via Terraform / the deploy command.

# STEAM_API_KEY=your-api-key

# Runtime provider: Vertex AI
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global
GEMINI_MODEL=gemini-flash-latest

# Runtime provider: Gemini API via Google AI Studio
# Comment out the Vertex block above and uncomment:
# GEMINI_API_KEY=your-api-key-here
# GEMINI_MODEL=gemini-flash-latest

# Runtime provider: LiteLLM proxy-backed OpenAI model
# Comment out the Vertex block above and uncomment:
# LITELLM_PROXY_URL=https://your-proxy-host/v1
# LITELLM_PROXY_API_KEY=your-proxy-key-here
# OPENAI_MODEL=openai/gpt-4o-mini
#
# Runtime provider: direct OpenAI
# Comment out the Vertex block above and uncomment:
# OPENAI_API_KEY=your-openai-api-key-here
# OPENAI_MODEL=gpt-4o-mini

# Optional local override if you want to force a different model temporarily
# without changing the main provider block:
# DEADLOCK_COACH_MODEL_OVERRIDE=

# Eval judge configuration can be set separately from the app runtime.
# This is useful if the app uses a Cloud Run LiteLLM proxy, but you want
# `agents-cli eval grade` to use a simpler direct provider locally.
#
# Example: direct OpenAI judge for evals
# EVAL_JUDGE_PROVIDER=openai
# EVAL_OPENAI_API_KEY=your-openai-api-key-here
# EVAL_OPENAI_MODEL=gpt-4o-mini
#
# Example: direct Gemini API judge for evals
# EVAL_JUDGE_PROVIDER=gemini_api
# EVAL_GEMINI_API_KEY=your-gemini-api-key-here
# EVAL_GEMINI_MODEL=gemini-flash-latest
#
# Example: explicit proxy-backed eval judge
# EVAL_JUDGE_PROVIDER=litellm_proxy
# EVAL_LITELLM_PROXY_URL=https://your-proxy-host/v1
# EVAL_LITELLM_PROXY_API_KEY=your-proxy-key-here
# EVAL_OPENAI_MODEL=gpt-4o-mini
